# Backend AI extraction key (used by server/index.js)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash-lite,gemini-2.0-flash-exp,gemini-1.5-flash-latest,gemini-1.5-flash,gemini-1.5-pro-latest,gemini-1.5-pro

# Runtime
NODE_ENV=production
PORT=3000

# Trust reverse proxy (Dokploy/Nginx/Traefik)
TRUST_PROXY=1

# Limits and resilience
MAX_UPLOAD_MB=25
GEMINI_TIMEOUT_MS=30000
EXTRACT_RATE_LIMIT_PER_MIN=20
