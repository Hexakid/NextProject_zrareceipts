PORT=3000
NODE_ENV=development

# Database
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=expense_manager
DB_USER=postgres
DB_PASSWORD=postgres
SQLITE_STORAGE=./data/expense-manager.sqlite

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# File Storage
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Email (Optional - use Gmail or SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@expensemanager.local

# Firebase Cloud Messaging (for push notifications)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-email

# Gemini API (for OCR fallback)
GEMINI_API_KEY=your-gemini-api-key

# VAT Collector Integration
VAT_COLLECTOR_API_URL=http://localhost:3001/api
VAT_COLLECTOR_DATA_DIR=../VAT\ Reciept\ Data\ Collector\ -\ App/data

# Business Settings
BUDGET_ALERT_THRESHOLD_PERCENT=80
AUTO_APPROVE_THRESHOLD=500
APPROVAL_LEVEL_2_THRESHOLD=5000
