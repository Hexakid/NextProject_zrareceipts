# Backend AI extraction key (used by server/index.js)
GEMINI_API_KEY=your_gemini_api_key_here

# Runtime
NODE_ENV=production
PORT=3000

# Trust reverse proxy (Dokploy/Nginx/Traefik)
TRUST_PROXY=1

# Limits and resilience
MAX_UPLOAD_MB=25
GEMINI_TIMEOUT_MS=30000
EXTRACT_RATE_LIMIT_PER_MIN=20

# Optional frontend API base URL override (only if frontend and API are on different domains)
# VITE_API_BASE_URL=https://your-api-domain.com
